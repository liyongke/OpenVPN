# Server bind (keep localhost for safety in phase 1)
PORTAL_HOST=127.0.0.1
PORTAL_PORT=8088

# Optional explicit OpenVPN files.
# If OPENVPN_STATUS_FILE is empty, the app probes common paths.
OPENVPN_STATUS_FILE=
OPENVPN_STATUS_FILES=/var/log/openvpn/status-tcp.log,/var/log/openvpn/status-udp.log
OPENVPN_LOG_FILE=

# 7-day history storage (SQLite on local disk)
PORTAL_HISTORY_DB=/home/ec2-user/apps/vpn-portal-phase1-readonly/data/history.sqlite3
PORTAL_HISTORY_RETENTION_DAYS=7
PORTAL_HISTORY_SAMPLE_SECONDS=60
PORTAL_LIVE_POLL_SECONDS=1.0
PORTAL_DEVICE_HINTS_FILE=/home/ec2-user/apps/vpn-portal-phase1-readonly/device_hints.json

# Display name
PORTAL_TITLE=OpenVPN Portal Phase 2 (Read-Only Ops)
